# MedRack frontend environment variables.
# Copy to .env / .env.production before `npm run build`.

# Production (Windows browser → Ubuntu API on LAN):
VITE_MEDRACK_API_BASE=http://192.168.29.82:8010/api/v1

# Local dev only (backend on same machine):
# VITE_MEDRACK_API_BASE=http://127.0.0.1:8010/api/v1
