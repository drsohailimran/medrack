# MedRack frontend environment variables.
# Copy this file to .env and fill in the values.

# The base URL of the MedRack backend API.
# In dev (running the backend locally on the same machine): default below.
# In prod: point to the deployed backend (Tailscale, LAN, etc.).
VITE_MEDRACK_API_BASE=http://localhost:8000/api/v1
