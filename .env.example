# ============================================================
#  MedRack runtime configuration
#  install.sh copies this to .env on first run.
#  This file is sourced by bash, so $HOME etc. expand normally.
# ============================================================

# Data root: books, modules, generated answers, ChromaDB index, logs.
# Created by `medrack init` (install.sh does this for you).
MEDRACK_HOME=$HOME/.medrack

# LLM mode:
#   real  -> uses the OpenCode/Zen API (REQUIRES OPENCODE_ZEN_API_KEY below)
#   mock  -> fully offline, deterministic stub answers (no key needed)
MEDRACK_LLM_MODE=real

# Required when MEDRACK_LLM_MODE=real. Paste your OpenCode/Zen API key here.
OPENCODE_ZEN_API_KEY=

# ---- Ports ----
API_PORT=8000
FRONTEND_PORT=3000

# Frontend build-time API base URL (baked into the browser bundle by install.sh).
# Keep localhost if you open the UI on the same machine.
# If you'll open it from another device, set this to http://<this-box-LAN-IP>:8000/api/v1
# and re-run ./install.sh (or rebuild the frontend).
MEDRACK_API_BASE=http://localhost:8000/api/v1

# ---- Optional: Telegram operator bot ----
# Set both to enable the bot; run.sh starts it automatically when the token is present.
# MEDRACK_TELEGRAM_BOT_TOKEN=
# MEDRACK_OPERATOR_CHAT_ID=
