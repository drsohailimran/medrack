# ============================================================================
#  MedRack runtime configuration
#  Copy this file to `.env` (install.sh does this automatically on first run).
#  This file is sourced by bash, so $HOME and other variables expand normally.
#  NEVER commit your real .env — it is git-ignored.
# ============================================================================

# --- Data root --------------------------------------------------------------
# Everything MedRack stores lives here: uploaded books, the ChromaDB vector
# index, extracted question banks, generated answers, and logs.
# Created by `medrack init` (install.sh runs this for you).
MEDRACK_HOME=$HOME/medrack-data

# --- Ports ------------------------------------------------------------------
# Defaults avoid clashing with a common 8000/3000 setup. Change if taken.
API_PORT=8010
FRONTEND_PORT=3010

# Frontend build-time API base URL. This is BAKED into the browser bundle by
# install.sh, so if you change it you must rebuild the frontend.
#  - Same machine only:   http://localhost:8010/api/v1
#  - Access from the LAN:  http://<THIS-MACHINE-LAN-IP>:8010/api/v1
MEDRACK_API_BASE=http://localhost:8010/api/v1

# ============================================================================
#  LLM provider — pick ONE of the two options below.
# ============================================================================

# --- Option A: Google Gemini (cloud, free tier) -----------------------------
# Easiest to start with. Get a free key at https://aistudio.google.com/apikey
# Uncomment these three lines and paste your key:
# MEDRACK_LLM_PROVIDER=gemini
# MEDRACK_LLM_MODEL=gemini-2.0-flash
# GEMINI_API_KEY=your-key-here

# --- Option B: Local model via llama.cpp (no API key, no rate limits) --------
# Run a llama.cpp server (e.g. Qwen/Qwopus 30B-A3B) on a machine with a GPU,
# then point MedRack at it. The GPU machine can be this box or another host on
# the LAN (see docs/SETUP.md → "Running a local model").
MEDRACK_LLM_PROVIDER=llamacpp
MEDRACK_LLM_MODEL=qwopus
MEDRACK_LLM_BASE_URL=http://localhost:8080
# Local models are slower per token; give each attempt a generous timeout.
MEDRACK_LLM_TIMEOUT=600

# --- Advanced (optional) ----------------------------------------------------
# Force CPU/GPU for the embedding model (sentence-transformers). Default: cpu.
# MEDRACK_EMBED_DEVICE=cpu
# Offline, deterministic stub answers for testing the UI without any LLM:
# MEDRACK_LLM_MODE=mock
